<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.transkrip.view.DashboardController"
      styleClass="content-area"
      spacing="0">

    <!-- Header -->
    <VBox spacing="4">
        <Label fx:id="lblSambutan" text="Selamat Datang!" styleClass="page-heading"/>
        <Label text="Ringkasan akademik &amp; tren IPS kamu" styleClass="page-subheading"/>
    </VBox>

    <Region prefHeight="20"/>

    <!-- Stat Cards -->
    <HBox spacing="14">
        <VBox styleClass="stat-card, stat-card-teal" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="IPK KUMULATIF" styleClass="stat-card-label"/>
            <Label fx:id="lblIPK" text="0.00" styleClass="stat-card-value, stat-teal"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-blue" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="TOTAL SKS" styleClass="stat-card-label"/>
            <Label fx:id="lblSKS" text="0" styleClass="stat-card-value, stat-blue"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-amber" spacing="6" HBox.hgrow="ALWAYS">
            <Label text="SEMESTER DITEMPUH" styleClass="stat-card-label"/>
            <Label fx:id="lblSemester" text="-" styleClass="stat-card-value, stat-amber"/>
        </VBox>
    </HBox>

    <Region prefHeight="18"/>

    <!-- Line Chart -->
    <VBox styleClass="section-card" spacing="12">
        <Label text="Grafik Tren IPS per Semester" styleClass="section-title"/>

        <LineChart fx:id="chartIPS" prefHeight="260" animated="true"
                   legendVisible="false" styleClass="chart" createSymbols="true">
            <xAxis>
                <NumberAxis label="Semester" tickUnit="1.0" minorTickVisible="false"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="IPS" lowerBound="0" upperBound="4" tickUnit="0.5"/>
            </yAxis>
        </LineChart>

        <Label fx:id="lblKosong"
               text="Belum ada data. Tambahkan mata kuliah terlebih dahulu."
               style="-fx-text-fill:#5a5a7a;-fx-font-size:13px;-fx-wrap-text:true;"
               visible="false" managed="false"/>
    </VBox>

    <Region prefHeight="18"/>

    <!-- Tabel Detail IPS -->
    <VBox styleClass="section-card" spacing="12">
        <Label text="Detail IPS per Semester" styleClass="section-title"/>

        <HBox style="-fx-background-color:#1c1c2e;-fx-background-radius:6;-fx-padding:8 14;">
            <Label text="SEMESTER"   style="-fx-min-width:140;-fx-text-fill:#5a5a7a;-fx-font-size:11px;-fx-font-weight:bold;"/>
            <Label text="IPS"        style="-fx-min-width:80;-fx-text-fill:#5a5a7a;-fx-font-size:11px;-fx-font-weight:bold;"/>
            <Label text="SKS"        style="-fx-min-width:80;-fx-text-fill:#5a5a7a;-fx-font-size:11px;-fx-font-weight:bold;"/>
            <Label text="PROGRESS"   style="-fx-min-width:160;-fx-text-fill:#5a5a7a;-fx-font-size:11px;-fx-font-weight:bold;"/>
            <Label text="KETERANGAN" style="-fx-text-fill:#5a5a7a;-fx-font-size:11px;-fx-font-weight:bold;"/>
        </HBox>

        <VBox fx:id="vboxDetailIPS" spacing="0"/>
    </VBox>

    <Region prefHeight="18"/>

    <!-- Quick Action -->
    <HBox spacing="10">
        <Button text="+ Tambah Mata Kuliah" styleClass="btn-primary"   onAction="#goTambah"/>
        <Button text="Lihat Riwayat Nilai"  styleClass="btn-secondary" onAction="#goRiwayat"/>
    </HBox>

    <Region prefHeight="10"/>

</VBox>